# PostgreSQL (n8n internal database)
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=choose_a_secure_password_here
POSTGRES_DB=n8n_database

# Public n8n URL (must match nginx + SSL certificate)
N8N_HOST=n8n.yourdomain.com
WEBHOOK_URL=https://n8n.yourdomain.com/

# Timezone for scheduled workflows
GENERIC_TIMEZONE=Asia/Riyadh

# Supabase — used by mken-whatsapp-saas workflow to fetch tenant settings
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
